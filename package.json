{
  "name": "ccgui",
  "productName": "CCGUI",
  "version": "1.0.0",
  "description": "Electron + Vue3 application",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npx electron .\" --kill-others",
    "electron": "npx electron .",
    "electron:build": "npm run build && electron-builder",
    "rebuild": "./scripts/rebuild.sh",
    "rebuild:fast": "./scripts/rebuild.sh --skip-clean",
    "rebuild:only": "./scripts/rebuild.sh --only-build",
    "debug": "./scripts/debug.sh",
    "debug:tools": "./scripts/debug.sh --devtools",
    "debug:quiet": "./scripts/debug.sh --no-logs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "build": {
    "productName": "CCGUI",
    "appId": "com.ccgui.app",
    "directories": {
      "output": "output"
    },
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "extendInfo": {
        "CFBundleName": "CCGUI",
        "CFBundleDisplayName": "CCGUI",
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Folder",
            "CFBundleTypeRole": "Viewer",
            "LSItemContentTypes": [
              "public.folder",
              "public.directory"
            ],
            "LSHandlerRank": "Alternate"
          }
        ]
      }
    }
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^17.0.3",
    "pinia": "^3.0.4",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^26.6.10",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
